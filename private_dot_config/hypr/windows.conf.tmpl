{{- $location := .monitors.selected -}}
{{- $selectedMonitors := index .monitors $location -}}
{{- $defaultProfile := .monitors.default_profile | default (index $selectedMonitors "default_profile") -}}
{{- $activeProfile := $defaultProfile -}}
{{- /* TODO: replace the ACTIVE_PROFILE placeholder with the real shikane active-profile query once it is available. */ -}}
{{- $profileFromEnv := trim (output "sh" "-lc" "printf '%s' \"$ACTIVE_PROFILE\"") -}}
{{- if ne $profileFromEnv "" -}}
  {{- $activeProfile = $profileFromEnv -}}
{{- end -}}
{{- if hasKey . "runtime" -}}
  {{- $runtime := index . "runtime" -}}
  {{- if and $runtime (hasKey $runtime "active_profile") -}}
    {{- $runtimeProfile := trim (index $runtime "active_profile") -}}
    {{- if ne $runtimeProfile "" -}}
      {{- $activeProfile = $runtimeProfile -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $workspaceSets := .workspaces -}}
{{- $visibleRoles := dict -}}
{{- range $role := list "left" "center" "right" "laptop" "tv" -}}
  {{- if hasKey $selectedMonitors $role -}}
    {{- $monitor := index $selectedMonitors $role -}}
    {{- if and (kindIs "map" $monitor) (hasKey $monitor "workspaces") (hasKey $monitor "profiles") (has $activeProfile (index $monitor "profiles")) -}}
      {{- $_ := set $visibleRoles $role true -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $visibleSets := dict -}}
{{- range $role := list "left" "center" "right" "laptop" "tv" -}}
  {{- if hasKey $visibleRoles $role -}}
    {{- $monitor := index $selectedMonitors $role -}}
    {{- $setName := index $monitor "workspaces" -}}
    {{- if and (eq $role "laptop") (eq (len $visibleRoles) 1) -}}
      {{- $setName = "center" -}}
    {{- end -}}
    {{- $_ := set $visibleSets $setName true -}}
  {{- end -}}
{{- end -}}
{{- $workspaceToSet := dict -}}
{{- range $setName, $members := $workspaceSets -}}
  {{- if and (ne $setName "associations") (kindIs "slice" $members) -}}
    {{- range $workspace := $members -}}
      {{- $_ := set $workspaceToSet (printf "%v" $workspace) $setName -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $associationTargets := dict -}}
{{- $associationResolvedVisible := dict -}}
{{- range $associationName, $members := index $workspaceSets "associations" -}}
  {{- if gt (len $members) 0 -}}
    {{- $_ := set $associationTargets $associationName (index $members 0) -}}
  {{- end -}}
  {{- range $workspace := $members -}}
    {{- $workspaceKey := printf "%v" $workspace -}}
    {{- $setName := index $workspaceToSet $workspaceKey | default "" -}}
    {{- if and (not (hasKey $associationResolvedVisible $associationName)) (hasKey $visibleSets $setName) -}}
      {{- $_ := set $associationTargets $associationName $workspace -}}
      {{- $_ := set $associationResolvedVisible $associationName true -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $mailWorkspace := index $associationTargets "mail" -}}
{{- $mediaWorkspace := index $associationTargets "media" -}}
{{- $messagesWorkspace := index $associationTargets "messages" -}}
{{- $chatsWorkspace := index $associationTargets "chats" -}}
{{- $workCommWorkspace := index $associationTargets "work_comm" -}}

# Disable kitty/terminal shadow.
windowrule {
	name = noshadow-kitty
	match:class = ^(kitty)$

	no_shadow = on
}

windowrule {
	name = noshadow-ghostty
	match:class = ^(com\.mitchellh\.ghostty)$

	no_shadow = on
}

# Floats for small utility apps
windowrule {
	name = Float
	match:class = ^(1password)|(com.adamcake.Bolt)$

	float = on
}

windowrule {
	name = 1password-quickaccess
	match:title = ^(Quick Access — 1Password)$

	stay_focused = on
	dim_around = on
}
windowrule {
	name = kitty-noshadow
	match:class = ^(kitty)$

	no_shadow = on
}

windowrule {
	name = ghostty-noshadow
	match:class = ^(com\.mitchellh\.ghostty)$

	no_shadow = on
}

# RuneLite Launcher / HDOS Launcher
windowrule {
	name = rs-launcher
	match:title = ^(RuneLite\sLauncher)|(HDOS)$

	float = on
	center = on
	pin = on

}

# Disable kitty/terminal shadow.
windowrule {
	name = noshadow-kitty
	match:class = ^(kitty)$

	no_shadow = on
}

windowrule {
	name = noshadow-ghostty-dup
	match:class = ^(com\.mitchellh\.ghostty)$

	no_shadow = on
}

# Floats for small utility apps
windowrule {
	name = float-1password-bolt
	match:class = ^(1password)|(com.adamcake.Bolt)$

	float = on
}

windowrule {
	name = 1password-quickaccess
	match:title = ^(Quick Access — 1Password)|(1Password)$

	stay_focused = on
	dim_around = on
}

# RuneLite Launcher / HDOS Launcher
windowrule {
	name = runelite-launcher
	match:title = ^(RuneLite\sLauncher)|(HDOS)$

	float = on
	center = on
	pin = on
}
windowrule {
	name = hdos-main-tile
	match:class = ^(hdos-Main)$

	tile = on
}

# 1Password menu windows / Zoom helpers
windowrule {
	name = zoom
	match:class = ^(Zoom.*)$

	float = on
	move = (cursor_x-10) (cursor_y-10)
}
windowrule {
	name = zoom-menu-size
	match:class = ^(Zoom.*)$
	match:title = ^(menu window)$

	size = 300 201
}

# small floats: prompts, update dialogs
windowrule {
	name = floats-others
	match:class = ^(Gtk_prompt\.py)|(updates)$

	float = on
}

# Picture in Picture
windowrule {
	name = picture-in-picture
	match:title = ^(Picture-in-Picture)$

	float = on
	keep_aspect_ratio = on
	size = 800 450
}
windowrule {
	name = picture-in-picture-opacity
	match:pin = true

	opacity = 0.10 1.0
}

# Left
# Workspace 1
windowrule {
	name = workspace-1-thunderbird
	match:class = ^(thunderbird)$

	workspace = {{ $mailWorkspace }} silent
}

# Workspace 2
windowrule {
	name = workspace-2-spotify
	match:class = ^(Spotify(\sPremium)?)$

	workspace = {{ $mediaWorkspace }} silent
}
# On Wayland Spotify opens without a class.
windowrule {
	name = workspace-2-spotify-initialtitle
	match:initial_title = ^(Spotify(\sPremium)?)$

	workspace = {{ $mediaWorkspace }} silent
}

