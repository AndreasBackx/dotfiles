{{- $t := .themes.rubecula -}}
$mako-bg: #1c1c1c;
$mako-bg-low: #141414;
$mako-layer: #242424;
$mako-border: #404040;
$mako-text: #cecece;

* {
  all: unset;
  font-family: monospace, "MesloLGM Nerd Font";
  font-size: 14px;
  color: $mako-text;
}

.bar-root,
.left-side,
.center-side,
.right-side,
.workspace-segment,
.title-segment,
.system-segment {
  background: $mako-bg;
  color: $mako-text;
}

.bar-root {
  margin: 0;
  padding: 0;
  min-height: 56px;
  border-top: 1px solid $mako-layer;
}

.left-side,
.center-side,
.right-side {
  min-width: 1px;
}

.left-side,
.center-side,
.workspace-segment,
.title-segment,
.window-title,
.system-segment {
  min-width: 0;
}

.left-side {
  padding-left: 6px;
}

.right-side {
  padding-right: 6px;
}

.workspace-row,
.system-segment {
  min-width: 0;
}

.workspace-row {
  min-height: 56px;
}

.workspace-btn {
  min-width: 0;
  min-height: 56px;
  padding: 0 10px;
  margin: 0;
  border: none;
  border-bottom: 2px solid $mako-bg;
  border-radius: 0;
  background: transparent;
  color: #8a8a8a;
  transition: color 120ms ease, background-color 120ms ease;
}

.workspace-btn.shown {
  border-bottom-color: $mako-text;
  color: $mako-text;
}

.workspace-btn:hover,
.bar-button:hover,
.bar-item:hover,
.panel-button:hover {
  background: $mako-layer;
}

.window-title {
  color: $mako-text;
  padding: 0 12px 0 14px;
}

.spotify-text {
  color: $mako-text;
  padding: 0 26px;
}

.bar-item {
  min-width: 0;
  padding: 0 11px;
  border: none;
  border-radius: 3px;
  background: transparent;
  transition: background-color 120ms ease, color 120ms ease;
}

.bar-item.icon-only {
  padding: 0 8px;
  min-width: 20px;
}

.bar-item.with-text {
  padding: 0 10px;
  min-width: 52px;
}

.bar-item-content {
  min-width: 0;
}

.bar-item-content.icon-only {
  min-width: 12px;
}

.bar-item-content.with-text {
  min-width: 38px;
}

.item-icon {
  margin-right: 6px;
  font-family: "MesloLGM Nerd Font Mono", "Symbols Nerd Font Mono", monospace;
}

.item-icon-only {
  margin-right: 0;
  font-family: "MesloLGM Nerd Font Mono", "Symbols Nerd Font Mono", monospace;
}

.item-text {
  min-width: 0;
}

.bar-button {
  min-width: 0;
  min-height: 0;
  padding: 0;
  border: none;
  background: transparent;
  color: $mako-text;
}

.bar-item.bt-off,
.bar-item.net-offline {
  color: #7a7a7a;
}

.clock,
.tray-segment {
  border: none;
  background: transparent;
}

.bar-center-trigger {
  min-height: 14px;
  background: transparent;
}

.bar-center-shell {
  background: $mako-bg;
  min-height: 56px;
  margin-top: 0;
  opacity: 1;
  transition: margin-top 220ms ease, opacity 220ms ease;
}

.bar-center-hide-shell {
  min-height: 56px;
  background: transparent;
}

.bar-center-shell-hiding {
  margin-top: 57px;
  opacity: 0.01;
}

.tray-segment {
  padding: 0 8px;
}

.tray-segment > widget > image,
.tray-segment image {
  -gtk-icon-transform: scale(0.9);
}

menu {
  background: $mako-bg;
  color: $mako-text;
  border: 1px solid $mako-border;
  border-radius: 3px;
  padding: 4px;
}

menu menuitem {
  padding: 6px 10px;
  color: $mako-text;
  background: transparent;
  border-radius: 2px;
}

menu menuitem:hover,
menu menuitem:focus {
  background: $mako-layer;
  color: $mako-text;
}

menu separator {
  background: $mako-layer;
  min-height: 1px;
  margin: 3px 2px;
}

tooltip {
  background: $mako-bg-low;
  border: 1px solid $mako-border;
  border-radius: 4px;
  color: $mako-text;
  margin-bottom: 10px;
  padding: 0;
}

tooltip label {
  color: $mako-text;
  padding: 6px 9px;
}

.panel {
  background: $mako-bg;
  border: 1px solid $mako-border;
  border-radius: 3px;
  padding: 12px;
  color: $mako-text;
  font-family: "MesloLGM Nerd Font Mono", monospace;
  font-size: 13px;
}

.panel.state-low {
  background: $mako-bg-low;
  border-color: $mako-layer;
  color: #9a9a9a;
}

.panel.state-normal {
  border-color: $mako-border;
}

.panel.state-critical {
  border-color: {{ $t.color1 }};
}

.panel.state-success {
  border-color: {{ $t.color10 }};
}

.panel-state-low {
  color: #9a9a9a;
}

.panel-state-normal {
  color: $mako-text;
}

.panel-state-critical {
  color: {{ $t.color1 }};
}

.panel-state-success {
  color: {{ $t.color10 }};
}

.panel-title {
  color: $mako-text;
  font-size: 14px;
}

.panel-header {
  margin-bottom: 8px;
}

.panel-section-title {
  color: #b6b6b6;
  margin-top: 8px;
  margin-bottom: 2px;
}

.panel-status {
  color: #b0b0b0;
  margin-bottom: 4px;
}

.panel-row {
  margin-bottom: 2px;
}

.panel-button {
  background: transparent;
  border: 1px solid $mako-layer;
  border-radius: 3px;
  padding: 4px 8px;
}

.panel-button.panel-close {
  min-width: 22px;
  padding: 4px 6px;
}

.panel-button.occupied {
  border-color: $mako-border;
}

.panel-button.danger {
  border-color: {{ $t.color1 }};
}

.panel-button.danger:hover {
  background: $mako-layer;
  color: $mako-text;
}

.spotify-text.spotify-paused,
.spotify-text.spotify-stopped,
.center-segment.spotify-paused,
.center-segment.spotify-stopped {
  color: #7a7a7a;
}
