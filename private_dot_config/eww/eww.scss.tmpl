{{- $t := .themes.rubecula -}}
* {
  all: unset;
  font-family: monospace, "MesloLGM Nerd Font";
  font-size: 14px;
  color: {{ $t.foreground }};
}

.bar-root {
  margin: 0;
  padding: 0;
  color: {{ $t.foreground }};
  background: {{ $t.background }};
  border-top: none;
}

.left-side,
.center-side,
.right-side,
.workspace-segment,
.title-segment,
.system-segment {
  background: {{ $t.background }};
}

.left-side,
.center-side,
.right-side {
  min-width: 1px;
}

.left-side,
.center-side {
  min-width: 0;
}

.right-side {
  padding-right: 6px;
}

.center-side {
  padding: 0;
}

.left-side {
  padding-left: 6px;
}

.workspace-btn {
  min-width: 0;
  min-height: 0;
  padding: 4px 12px 3px 12px;
  border: none;
  border-bottom: 3px solid transparent;
  background: transparent;
  color: {{ $t.foreground }};
  transition: border-color 120ms ease, color 120ms ease, background-color 120ms ease;
}

.workspace-row,
.system-segment {
  min-width: 0;
}

.workspace-btn.shown {
  border-bottom-color: {{ $t.foreground }};
  color: {{ $t.foreground }};
}

.window-title {
  color: {{ $t.foreground }};
  padding: 0 12px 0 16px;
}

.spotify-text {
  color: {{ $t.foreground }};
  padding: 0 32px;
}

.bar-item {
  min-width: 0;
  padding: 0 12px;
  border: none;
  border-radius: 4px;
  background: transparent;
  transition: background-color 120ms ease, color 120ms ease;
}

.bar-item.icon-only {
  padding: 0 8px;
  min-width: 20px;
}

.bar-item.with-text {
  padding: 0 10px;
  min-width: 44px;
}

.bar-item-content {
  min-width: 0;
}

.bar-item-content.icon-only {
  min-width: 12px;
}

.bar-item-content.with-text {
  min-width: 36px;
}

.item-icon {
  margin-right: 6px;
  font-family: "MesloLGM Nerd Font Mono", "Symbols Nerd Font Mono", monospace;
}

.item-icon-only {
  margin-right: 0;
  font-family: "MesloLGM Nerd Font Mono", "Symbols Nerd Font Mono", monospace;
}

.item-text {
  min-width: 0;
}

.title-segment {
  min-width: 0;
}

.window-title {
  margin-left: 0;
}

.bar-button {
  min-width: 0;
  min-height: 0;
  padding: 0;
  border: none;
  background: transparent;
  color: {{ $t.foreground }};
}

.workspace-btn:hover,
.bar-button:hover,
.bar-item:hover {
  background: {{ $t.color0 }};
  color: {{ $t.color3 }};
}

.bar-item.bt-off {
  color: {{ $t.color0 }};
}

.bar-item.net-offline {
  color: {{ $t.color0 }};
}

.clock {
  border: none;
  background: transparent;
}

.clock:hover {
  border: none;
}

.panel {
  background: {{ $t.background }};
  border: 1px solid {{ $t.color6 }};
  border-radius: 10px;
  padding: 10px;
  color: {{ $t.foreground }};
  font-family: "MesloLGM Nerd Font Mono";
  font-size: 13px;
}

.panel-title {
  color: {{ $t.color6 }};
  font-size: 14px;
  margin-bottom: 8px;
}

.panel-section-title {
  color: {{ $t.color3 }};
  margin-top: 8px;
}

.panel-button {
  background: {{ $t.background }};
  border: none;
  border-radius: 6px;
  padding: 4px 7px;
}

.panel-button:hover {
  background: {{ $t.color0 }};
  color: {{ $t.foreground }};
}

.panel-button.danger:hover {
  background: {{ $t.color0 }};
  color: {{ $t.foreground }};
}
