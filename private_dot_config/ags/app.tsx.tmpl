            <button onClicked={() => run(["bluetoothctl", "scan", "off"])}>scan off</button>
          </box>
          <label class="panel-section-title" label="Known devices" xalign={0} />
          <box orientation={Gtk.Orientation.VERTICAL} spacing={6}>
