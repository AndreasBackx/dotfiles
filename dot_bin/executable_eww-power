#!/usr/bin/env zsh

set -euo pipefail

render() {
    print '(box :orientation "v" :spacing 10 :class "panel-state-normal"'
    print '  (label :class "panel-title" :text "Power")'
    print '  (label :class "panel-section-title" :text "Session")'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "power-options logout" "logout")'
    print '    (button :class "panel-button" :onclick "power-options suspend" "suspend")'
    print '    (button :class "panel-button" :onclick "power-options hibernate" "hibernate"))'
    print '  (label :class "panel-section-title" :text "System")'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "power-options reboot" "reboot")'
    print '    (button :class "panel-button danger" :onclick "power-options shutdown" "shutdown"))'
    print '  (label :class "panel-section-title" :text "After updates")'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "power-options update-reboot" "update + reboot")'
    print '    (button :class "panel-button" :onclick "power-options update-shutdown" "update + shutdown"))'
    print '  (button :class "panel-button danger" :onclick "eww-bar close-panels" "close")'
    print ')'
}

panel_state() {
    echo "normal"
}

case "${1:-render}" in
render)
    render
    ;;
panel-state)
    panel_state
    ;;
*)
    echo "Usage: $0 {render|panel-state}"
    exit 2
    ;;
esac
