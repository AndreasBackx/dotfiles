#!/usr/bin/env zsh

set -euo pipefail

render() {
    print '(box :orientation "v" :spacing 10 :class "panel-state-normal"'
    print '  (box :class "panel-header" :orientation "h" :spacing 8 :space-evenly false'
    print '    (label :class "panel-title" :hexpand true :xalign 0 :text "Power")'
    print '    (button :class "panel-button panel-close" :onclick "~/.bin/eww-bar close-panel power" "x"))'
    print '  (label :class "panel-section-title" :text "Session")'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options logout" "logout")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options suspend" "suspend")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options hibernate" "hibernate"))'
    print '  (label :class "panel-section-title" :text "System")'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options reboot" "reboot")'
    print '    (button :class "panel-button danger" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options shutdown" "shutdown"))'
    print '  (label :class "panel-section-title" :text "After updates")'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options update-reboot" "update + reboot")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close power; power-options update-shutdown" "update + shutdown"))'
    print ')'
}

panel_state() {
    echo "normal"
}

case "${1:-render}" in
render)
    render
    ;;
panel-state)
    panel_state
    ;;
*)
    echo "Usage: $0 {render|panel-state}"
    exit 2
    ;;
esac
