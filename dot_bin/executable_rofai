#!/usr/bin/env zsh

# rofai
# ----
# A rofi front-end for GitHub Copilot CLI that keeps the interaction lightweight:
# - prompt in rofi
# - response preview in rofi
# - copy on Enter
# - optional full response view in Ghostty + Neovim
#
# The script stores all persistent state in XDG paths so it can be configured
# without editing the script itself:
# - ~/.config/rofai/config      selected model, effort, default agent
# - ~/.config/rofai/models      available model ids shown in the picker
# - ~/.config/rofai/agents/     one file per agent prefix prompt
# - ~/.local/state/rofai/       last prompt and last response cache

emulate -L zsh
setopt errexit nounset pipefail

readonly XDG_CONFIG_BASE="${XDG_CONFIG_HOME:-$HOME/.config}"
readonly XDG_STATE_BASE="${XDG_STATE_HOME:-$HOME/.local/state}"
readonly ROFAI_CONFIG_DIR="${XDG_CONFIG_BASE}/rofai"
readonly ROFAI_AGENTS_DIR="${ROFAI_CONFIG_DIR}/agents"
readonly ROFAI_CONFIG_FILE="${ROFAI_CONFIG_DIR}/config"
readonly ROFAI_MODELS_FILE="${ROFAI_CONFIG_DIR}/models"
readonly ROFAI_STATE_DIR="${XDG_STATE_BASE}/rofai"
readonly ROFAI_LAST_RESPONSE_FILE="${ROFAI_STATE_DIR}/last-response.txt"
readonly ROFAI_LAST_PROMPT_FILE="${ROFAI_STATE_DIR}/last-prompt.txt"
readonly ROFAI_RESPONSE_TITLE="rofai-response"
readonly ROFAI_TERMINAL_WIDTH="72%"
readonly ROFAI_TERMINAL_HEIGHT="78%"

# These are boot defaults only. User choices are loaded from XDG config.
typeset -g ROFAI_MODEL="gpt-5.4"
typeset -g ROFAI_EFFORT="medium"
typeset -g ROFAI_DEFAULT_AGENT="default"
typeset -g ROFAI_BIN_NAME="rofai"

function usage() {
    cat <<'EOF'
Usage:
  rofai
  rofai --agent NAME
  rofai --model MODEL
  rofai --effort LEVEL
  rofai --agent NAME --model MODEL
  rofai --print PROMPT [--agent NAME] [--model MODEL] [--effort LEVEL]
  rofai config show
  rofai config set-model MODEL
  rofai config set-effort LEVEL
  rofai config set-default-agent NAME
  rofai agents list
  rofai agents show NAME
  rofai agents set NAME PROMPT
  rofai agents edit NAME
  rofai agents remove NAME

Prompt UI shortcuts:
  Enter   submit prompt
  Alt+a   choose agent
  Alt+m   choose model
  Alt+Left / Alt+Right   change effort
  Escape  close

Response UI:
  Enter   copy response and close
  Alt+t   open full response in Ghostty + nvim
  Escape  close without copying
EOF
}

# Ensure the XDG directories exist before any read/write operation.
function ensure_paths() {
    mkdir -p "$ROFAI_CONFIG_DIR" "$ROFAI_AGENTS_DIR" "$ROFAI_STATE_DIR"
}

# Seed default config and starter content on first run.
# Agents are intentionally plain text files so they stay easy to edit manually.
function ensure_default_files() {
    ensure_paths

    if [[ ! -f "$ROFAI_CONFIG_FILE" ]]; then
        save_config
    fi

    if [[ ! -f "${ROFAI_AGENTS_DIR}/default.txt" ]]; then
        cat >"${ROFAI_AGENTS_DIR}/default.txt" <<'EOF'
EOF
    fi

    if [[ ! -f "${ROFAI_AGENTS_DIR}/research.txt" ]]; then
        cat >"${ROFAI_AGENTS_DIR}/research.txt" <<'EOF'
You are a careful web research agent. Use the web for current information, cite concrete details in your answer, and clearly call out uncertainty when sources disagree.
EOF
    fi

    if [[ ! -f "${ROFAI_AGENTS_DIR}/review.txt" ]]; then
        cat >"${ROFAI_AGENTS_DIR}/review.txt" <<'EOF'
You are a strict reviewer. Focus first on bugs, regressions, security issues, and missing edge cases. Keep the answer concise and prioritize concrete findings.
EOF
    fi

    if [[ ! -f "$ROFAI_MODELS_FILE" ]]; then
        cat >"$ROFAI_MODELS_FILE" <<'EOF'
gpt-5.4
gpt-5.3-codex
gpt-5.2-codex
gpt-5.2
gpt-5.1
gpt-5.4-mini
gpt-5-mini
gpt-4.1
claude-sonnet-4.6
claude-sonnet-4.5
claude-haiku-4.5
claude-opus-4.6
claude-opus-4.5
claude-sonnet-4
EOF
    fi
}

function load_config() {
    ensure_default_files
    source "$ROFAI_CONFIG_FILE"
    : "${ROFAI_MODEL:=gpt-5.4}"
    : "${ROFAI_EFFORT:=medium}"
    : "${ROFAI_DEFAULT_AGENT:=default}"
    ensure_model_in_list "$ROFAI_MODEL"
}

# Persist the active selections in a shell-sourceable config file.
function save_config() {
    ensure_paths
    printf '%s\n' '# shellcheck shell=sh' >"$ROFAI_CONFIG_FILE"
    printf 'ROFAI_MODEL=%q\n' "$ROFAI_MODEL" >>"$ROFAI_CONFIG_FILE"
    printf 'ROFAI_EFFORT=%q\n' "$ROFAI_EFFORT" >>"$ROFAI_CONFIG_FILE"
    printf 'ROFAI_DEFAULT_AGENT=%q\n' "$ROFAI_DEFAULT_AGENT" >>"$ROFAI_CONFIG_FILE"
}

function error() {
    print -u2 -- "$*"
}

# `die` is reserved for fatal errors where continuing the current flow would
# leave the UI or config in an inconsistent state.
function die() {
    error "$*"
    exit 1
}

function rofi_error() {
    local message="$1"

    if command -v rofi >/dev/null 2>&1; then
        rofi -e "$message" >/dev/null 2>&1 || true
    fi

    die "$message"
}

# Non-fatal message helper used when a dialog action should simply return to the
# previous picker instead of terminating the whole script.
function rofi_notice() {
    local message="$1"

    if command -v rofi >/dev/null 2>&1; then
        rofi -e "$message" >/dev/null 2>&1 || true
    else
        error "$message"
    fi
}

function require_command() {
    local name="$1"
    command -v "$name" >/dev/null 2>&1 || rofi_error "Missing required command: $name"
}

# Agent names are used as file names, so the accepted character set is narrow on
# purpose to keep path handling simple and predictable.
function validate_agent_name() {
    local name="$1"

    [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid agent name: $name"
}

# Effort is passed directly to `gh copilot --effort`, so only supported values
# are accepted here.
function validate_effort() {
    local value="$1"

    case "$value" in
    low|medium|high|xhigh) ;;
    *)
        die "Invalid effort: $value"
        ;;
    esac
}

# Map a logical agent name to its on-disk prompt file.
function agent_file() {
    local name="$1"
    validate_agent_name "$name"
    print -- "${ROFAI_AGENTS_DIR}/${name}.txt"
}

# Agents are listed alphabetically so the picker is stable and easy to scan.
function list_agents() {
    local file
    local -a names

    for file in "$ROFAI_AGENTS_DIR"/*.txt(.N); do
        names+=("${file:t:r}")
    done

    if (( ${#names[@]} == 0 )); then
        return 1
    fi

    printf '%s\n' "${(@on)names}"
}

function require_agent_exists() {
    local name="$1"
    local file

    file="$(agent_file "$name")"
    [[ -f "$file" ]] || die "Unknown agent: $name"
}

function agent_prompt() {
    local name="$1"
    local file

    file="$(agent_file "$name")"
    [[ -f "$file" ]] || return 1
    sed -n '1,$p' "$file"
}

# Convert an absolute path back to a `~/...` display path for the UI.
function display_path() {
    local path="$1"

    if [[ "$path" == "$HOME"* ]]; then
        print -- "~${path#$HOME}"
        return 0
    fi

    print -- "$path"
}

# Copilot model ids are stored normalized so custom entries and preset entries
# behave the same way in both the config file and the picker.
function normalize_model_id() {
    local value="${(L)1}"

    value="${value// /-}"
    value="${value//_/-}"

    while [[ "$value" == *--* ]]; do
        value="${value//--/-}"
    done

    value="${value#-}"
    value="${value%-}"

    print -- "$value"
}

# The model picker is backed by a simple newline-delimited file for the same
# reason as agents: easy manual editing, no extra parser dependency.
function list_models() {
    sed -n '1,$p' "$ROFAI_MODELS_FILE"
}

function save_models() {
    local -a models=("$@")
    printf '%s\n' "${models[@]}" >"$ROFAI_MODELS_FILE"
}

function ensure_model_in_list() {
    local model
    local -a models

    model="$(normalize_model_id "$1")"
    models=("${(@f)$(list_models)}")

    if (( ${models[(Ie)$model]} == 0 )); then
        models+=("$model")
        save_models "${models[@]}"
    fi
}

# Effort can be changed from the prompt without opening a separate picker.
function cycle_effort() {
    local current="$1"
    local direction="$2"
    local -a efforts=(low medium high xhigh)
    local index next_index

    index=${efforts[(Ie)$current]}
    (( index == 0 )) && index=2

    if [[ "$direction" == "left" ]]; then
        next_index=$(( index == 1 ? ${#efforts[@]} : index - 1 ))
    else
        next_index=$(( index == ${#efforts[@]} ? 1 : index + 1 ))
    fi

    print -- "${efforts[$next_index]}"
}

# Escape response text before sending it to rofi as Pango markup.
function pango_escape() {
    local text="$1"

    text="${text//&/&amp;}"
    text="${text//</&lt;}"
    text="${text//>/&gt;}"

    print -r -- "$text"
}

# Small helper to build multiline strings without literal `\n` artifacts.
function join_lines() {
    printf '%s\n' "$@"
}

