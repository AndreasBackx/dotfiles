#!/usr/bin/env zsh

set -euo pipefail

usage() {
  print -u2 -- "Usage: bar-dpms off|on [OUTPUT ...]"
  exit 2
}

if [[ $# -lt 1 ]]; then
  usage
fi

action="$1"
shift
targets=("$@")
if [[ ${#targets[@]} -eq 0 ]]; then
  targets=("*")
fi

stop_bar() {
  ags quit --instance dotfiles-bar >/dev/null 2>&1 || true
  sleep 0.2
}

start_bar() {
  "$HOME/.bin/bar-reload" >/dev/null 2>&1 || true
}

any_output_on() {
  wlopm 2>/dev/null | awk '$2 == "on" { found = 1 } END { exit found ? 0 : 1 }'
}

targets_are_on() {
  local target

  if [[ ${#targets[@]} -eq 1 && "${targets[1]}" == "*" ]]; then
    wlopm 2>/dev/null | awk '$2 != "on" { off = 1 } END { exit off ? 1 : 0 }'
    return
  fi

  for target in "${targets[@]}"; do
    if ! wlopm 2>/dev/null | awk -v target="$target" '$1 == target && $2 == "on" { found = 1 } END { exit found ? 0 : 1 }'; then
      return 1
    fi
  done
}

wait_for_targets_on() {
  local attempt

  for attempt in {1..40}; do
    if targets_are_on; then
      return 0
    fi

    sleep 0.25
  done
}

case "$action" in
off)
  stop_bar
  wlopm --off "${targets[@]}"
  sleep 0.3
  if any_output_on; then
    start_bar
  fi
  ;;
on)
  wlopm --on "${targets[@]}"
  wait_for_targets_on || true
  start_bar
  ;;
*)
  usage
  ;;
esac
