#!/usr/bin/env zsh

set -euo pipefail

panels=(panel-network panel-bluetooth panel-audio panel-brightness panel-power)
panel_names=(network bluetooth audio brightness power)
bars=(bar-left bar-right)
left_serial='{{ index .monitors .monitors.selected "left" "serial_number" }}'
center_serial='{{ index .monitors .monitors.selected "center" "serial_number" }}'
right_serial='{{ index .monitors .monitors.selected "right" "serial_number" }}'
left_name='{{ index .monitors .monitors.selected "left" "name" }}'
center_name='{{ index .monitors .monitors.selected "center" "name" }}'
right_name='{{ index .monitors .monitors.selected "right" "name" }}'
laptop_name='{{ index .monitors .monitors.selected "laptop" "name" | default "" }}'
home_center_name='{{ index .monitors.home.center "name" }}'
home_center_serial='{{ index .monitors.home.center "serial_number" }}'

hide_pid_file="${XDG_RUNTIME_DIR:-/tmp}/eww-center-hide.pid"
hide_token_file="${XDG_RUNTIME_DIR:-/tmp}/eww-center-hide.token"
center_state_file="${XDG_RUNTIME_DIR:-/tmp}/eww-center.state"
tooltip_target_file="${XDG_RUNTIME_DIR:-/tmp}/eww-bar-tooltip.target"
hide_anim_delay=0.24
hide_reveal_kick_delay=0.01
initial_autohide_delay=1.2
panel_idle_delay=5

set_center_state() {
    printf '%s' "$1" > "$center_state_file"
}

center_state() {
    if [[ -f "$center_state_file" ]]; then
        <"$center_state_file"
    else
        print -r -- "unknown"
    fi
}

panel_name() {
    local name="${1:?panel name required}"
    name=${name#panel-}

    case "$name" in
    network | bluetooth | audio | brightness | power)
        print -r -- "$name"
        ;;
    *)
        echo "Unknown panel: $name" >&2
        return 1
        ;;
    esac
}

panel_target() {
    print -r -- "panel-$(panel_name "$1")"
}

tooltip_target_name() {
    case "${1:?tooltip target required}" in
    spotify | network | bluetooth | brightness | audio | cpu | memory | battery | power | clock)
        print -r -- "$1"
        ;;
    *)
        echo "Unknown tooltip target: $1" >&2
        return 1
        ;;
    esac
}

panel_pid_file() {
    print -r -- "${XDG_RUNTIME_DIR:-/tmp}/eww-panel-$(panel_name "$1").pid"
}

panel_token_file() {
    print -r -- "${XDG_RUNTIME_DIR:-/tmp}/eww-panel-$(panel_name "$1").token"
}

close_panels() {
    local name
    for name in "${panel_names[@]}"; do
        close_panel "$name"
    done
}

cancel_panel_close() {
    local name pid_file token_file panel_pid
    name=$(panel_name "$1") || return 1
    pid_file=$(panel_pid_file "$name")
    token_file=$(panel_token_file "$name")

    if [[ -f "$pid_file" ]]; then
        panel_pid=$(<"$pid_file")
        if [[ -n "$panel_pid" ]]; then
            kill "$panel_pid" >/dev/null 2>&1 || true
        fi
        rm -f "$pid_file"
    fi

    rm -f "$token_file"
}

touch_panel() {
    cancel_panel_close "$1"
}

window_is_open() {
    local target="$1"
    eww active-windows 2>/dev/null | grep -q "^${target}:\|^${target}$"
}

monitor_connector_for_name() {
    local description="${1:?monitor name required}"

    hyprctl -j monitors all 2>/dev/null | jq -r --arg description "$description" '.[] | select(.description == $description) | .name' | head -n1
}

monitor_connector_for_serial() {
    local serial="${1:?monitor serial required}"

    hyprctl -j monitors all 2>/dev/null | jq -r --arg serial "$serial" '.[] | select(.serial == $serial) | .name' | head -n1
}

monitor_connector_required() {
    local serial="${1:-}"
    local description="${2:-}"
    local label="${3:-monitor}"
    local connector

    if [[ -n "$serial" ]]; then
        connector=$(monitor_connector_for_serial "$serial")
    fi

    if [[ -z "$connector" || "$connector" == "null" ]] && [[ -n "$description" ]]; then
        connector=$(monitor_connector_for_name "$description")
    fi

    if [[ -z "$connector" || "$connector" == "null" ]]; then
        echo "Could not resolve ${label} to a connector" >&2
        return 1
    fi

    print -r -- "$connector"
}

open_window() {
    local target="$1"
    eww open "$target" >/dev/null 2>&1 || true
}

open_window_on_screen() {
    local target="${1:?window required}"
    local screen="${2:?screen required}"
    eww open "$target" --screen "$screen" >/dev/null 2>&1 || true
}

open_window_for_serial() {
    local target="${1:?window required}"
    local serial="${2:-}"
    local description="${3:-}"
    local label="${4:-$target}"
    local connector

    connector=$(monitor_connector_required "$serial" "$description" "$label") || return 1
    open_window_on_screen "$target" "$connector"
}

tooltip_text() {
    local target
    target=$(tooltip_target_name "$1") || return 1

    case "$target" in
    spotify)
        ~/.bin/eww-spotify tooltip 2>/dev/null || true
        ;;
    network)
        ~/.bin/eww-network tooltip 2>/dev/null || true
        ;;
    bluetooth)
        ~/.bin/eww-bluetooth tooltip 2>/dev/null || true
        ;;
    brightness)
        ~/.bin/eww-brightness tooltip 2>/dev/null || true
        ;;
    audio)
        ~/.bin/eww-audio tooltip 2>/dev/null || true
        ;;
    battery)
        ~/.bin/eww-battery tooltip 2>/dev/null || true
        ;;
    clock)
        date '+%a %d %b %Y %H:%M:%S %Z'
        ;;
    cpu)
        print -r -- 'CPU usage'
        ;;
    memory)
        print -r -- 'Memory usage'
        ;;
    power)
        print -r -- 'Power options'
        ;;
    esac
}

cursor_monitor_json() {
    local cursor_json monitors_json

    cursor_json=$(hyprctl -j cursorpos 2>/dev/null) || return 1
    monitors_json=$(hyprctl -j monitors all 2>/dev/null) || return 1

    jq -cn --argjson cursor "$cursor_json" --argjson monitors "$monitors_json" '
        $monitors
        | map(select(.disabled == false and $cursor.x >= .x and $cursor.x < (.x + .width) and $cursor.y >= .y and $cursor.y < (.y + .height)))
        | .[0]
    '
}

tooltip_width_for_text() {
    local text="$1"
    local line max_length=0 length width

    while IFS= read -r line; do
        length=${#line}
        if (( length > max_length )); then
            max_length=$length
        fi
    done <<< "$text"

    width=$(( (max_length * 8) + 26 ))
    if (( width < 96 )); then
        width=96
    elif (( width > 420 )); then
        width=420
    fi

    print -r -- "$width"
}

tooltip_screen_and_offset() {
    local monitor_json width cursor_x monitor_x monitor_width offset max_offset screen

    width="${1:?tooltip width required}"
    monitor_json=$(cursor_monitor_json) || return 1

    screen=$(jq -r '.name // empty' <<< "$monitor_json")
    cursor_x=$(hyprctl -j cursorpos 2>/dev/null | jq -r '.x')
    monitor_x=$(jq -r '.x' <<< "$monitor_json")
    monitor_width=$(jq -r '.width' <<< "$monitor_json")

    [[ -n "$screen" ]] || return 1

    offset=$(( cursor_x - monitor_x - (width / 2) ))
    if (( offset < 12 )); then
        offset=12
    fi

    max_offset=$(( monitor_width - width - 12 ))
    if (( max_offset < 12 )); then
        max_offset=12
    fi
    if (( offset > max_offset )); then
        offset=$max_offset
    fi

    print -r -- "$screen"
    print -r -- "${offset}px"
}

tooltip_show() {
    local target text width screen offset

    target=$(tooltip_target_name "$1") || return 1
    text=$(tooltip_text "$target")
    [[ -n "$text" ]] || {
        tooltip_hide
        return 0
    }

    width=$(tooltip_width_for_text "$text")
    {
        IFS= read -r screen
        IFS= read -r offset
    } < <(tooltip_screen_and_offset "$width") || return 1

    print -r -- "$target" > "$tooltip_target_file"
    eww update bar_tooltip_text="$text" >/dev/null 2>&1 || true
    close_window bar-tooltip
    eww open bar-tooltip --screen "$screen" --arg tooltip_x="$offset" --arg tooltip_width="${width}px" >/dev/null 2>&1 || true
}

tooltip_hide() {
    close_window bar-tooltip
    rm -f "$tooltip_target_file"
}

monitor_present() {
    local serial="${1:-}"
    local description="${2:-}"

    monitor_connector_required "$serial" "$description" "monitor" >/dev/null 2>&1
}

center_target_serial() {
    if monitor_present "$center_serial" "$center_name"; then
        print -r -- "$center_serial"
        return
    fi

    if [[ -n "$laptop_name" ]] && monitor_present "" "$laptop_name"; then
        print -r -- ""
        return
    fi

    print -r -- "$center_serial"
}

center_target_name() {
    if monitor_present "$center_serial" "$center_name"; then
        print -r -- "$center_name"
        return
    fi

    if [[ -n "$laptop_name" ]] && monitor_present "" "$laptop_name"; then
        print -r -- "$laptop_name"
        return
    fi

    print -r -- "$center_name"
}

solo_laptop_center() {
    [[ -n "$laptop_name" ]] || return 1
    monitor_present "" "$laptop_name" || return 1
    monitor_present "$left_serial" "$left_name" && return 1
    monitor_present "$center_serial" "$center_name" && return 1
    monitor_present "$right_serial" "$right_name" && return 1
    return 0
}

assign_center_workspaces_to_laptop() {
    local workspace_id

    [[ -n "$laptop_name" ]] || return 1

    for workspace_id in {101..112}; do
        hyprctl keyword workspace "${workspace_id},monitor:desc:${laptop_name}" >/dev/null 2>&1 || true
    done
}

switch_to_center_workspace() {
    hyprctl dispatch workspace 101 >/dev/null 2>&1 || true
}

prepare_workspace_layout() {
    if solo_laptop_center; then
        assign_center_workspaces_to_laptop
        switch_to_center_workspace
    fi
}

close_window() {
    local target="$1"
    eww close "$target" >/dev/null 2>&1 || true
}

close_panel() {
    local name target
    name=$(panel_name "$1") || return 1
    target=$(panel_target "$name")
    cancel_panel_close "$name"
    close_window "$target"
}

schedule_panel_close() {
    local name delay token pid_file token_file target
    name=$(panel_name "$1") || return 1
    delay="${2:-$panel_idle_delay}"
    target=$(panel_target "$name")
    pid_file=$(panel_pid_file "$name")
    token_file=$(panel_token_file "$name")

    cancel_panel_close "$name"
    token="$$-$RANDOM-$RANDOM"
    printf '%s' "$token" > "$token_file"

    (
        local current_token
        sleep "$delay"
        [[ -f "$token_file" ]] || exit 0
        current_token=$(<"$token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        close_window "$target"
        rm -f "$pid_file" "$token_file"
    ) &

    printf '%s' "$!" > "$pid_file"
}

toggle_panel() {
    local name target
    local target_serial target_name
    name=$(panel_name "$1") || return 1
    target=$(panel_target "$name")

    tooltip_hide

    if window_is_open "$target"; then
        close_panel "$name"
        return
    fi

    close_panels
    target_serial=$(center_target_serial)
    target_name=$(center_target_name)
    open_window_for_serial "$target" "$target_serial" "$target_name" "center"
    schedule_panel_close "$name"
}

center_autohide_enabled() {
    local monitors
    if [[ -n "$laptop_name" && "$(center_target_name)" == "$laptop_name" ]]; then
        return 0
    fi

    monitors="$(hyprctl monitors all 2>/dev/null || true)"
    [[ -n "$monitors" ]] || return 1
    [[ "$monitors" == *"$home_center_name"* ]] || return 1
    [[ -z "$home_center_serial" || "$monitors" == *"$home_center_serial"* ]]
}

open_bars() {
    close_window bar-left
    close_window bar-right

    if solo_laptop_center; then
        return
    fi

    if monitor_present "$left_serial" "$left_name"; then
        open_window_for_serial bar-left "$left_serial" "$left_name" "left"
    fi

    if monitor_present "$right_serial" "$right_name"; then
        open_window_for_serial bar-right "$right_serial" "$right_name" "right"
    fi
}

open_center_windows() {
    local target_serial target_name
    target_serial=$(center_target_serial)
    target_name=$(center_target_name)
    tooltip_hide

    if center_autohide_enabled; then
        close_window bar-center
        eww update center_bar_auto=true >/dev/null 2>&1 || true
        eww update center_bar_tray=false >/dev/null 2>&1 || true
        eww update center_bar_hiding=false >/dev/null 2>&1 || true
        close_window bar-center-home
        close_window bar-center-hide
        close_window bar-center-trigger
        open_window_for_serial bar-center-home "$target_serial" "$target_name" "center"
        set_center_state visible
        center_hide_delayed "$initial_autohide_delay"
        return
    fi

    eww update center_bar_hiding=false >/dev/null 2>&1 || true
    if solo_laptop_center; then
        eww update center_bar_tray=true >/dev/null 2>&1 || true
    else
        eww update center_bar_tray=false >/dev/null 2>&1 || true
    fi
    close_window bar-center-home
    close_window bar-center-hide
    close_window bar-center-trigger
    eww update center_bar_auto=false >/dev/null 2>&1 || true
    open_window_for_serial bar-center "$target_serial" "$target_name" "center"
    set_center_state static
}

cancel_center_hide() {
    local hide_pid
    if [[ -f "$hide_pid_file" ]]; then
        hide_pid=$(<"$hide_pid_file")
        if [[ -n "$hide_pid" ]]; then
            kill "$hide_pid" >/dev/null 2>&1 || true
        fi
        rm -f "$hide_pid_file"
    fi
    rm -f "$hide_token_file"
}

center_show() {
    if ! center_autohide_enabled; then
        eww update center_bar_auto=false >/dev/null 2>&1 || true
        return
    fi
    cancel_center_hide
    tooltip_hide
    if [[ "$(center_state)" == "visible" ]]; then
        return
    fi

    set_center_state visible
    eww update center_bar_hiding=false >/dev/null 2>&1 || true
    open_window_for_serial bar-center-home "$(center_target_serial)" "$(center_target_name)" "center"

    (
        sleep 0.05
        close_window bar-center-hide
        close_window bar-center-trigger
    ) >/dev/null 2>&1 &
}

center_hide() {
    if ! center_autohide_enabled; then
        eww update center_bar_auto=false >/dev/null 2>&1 || true
        return
    fi
    cancel_center_hide
    tooltip_hide
    set_center_state hiding
    eww update center_bar_hiding=false >/dev/null 2>&1 || true
    open_window_for_serial bar-center-hide "$(center_target_serial)" "$(center_target_name)" "center"
    sleep "$hide_reveal_kick_delay"
    close_window bar-center-home
    eww update center_bar_hiding=true >/dev/null 2>&1 || true
    sleep "$hide_anim_delay"
    close_window bar-center-hide
    open_window_for_serial bar-center-trigger "$(center_target_serial)" "$(center_target_name)" "center"
    set_center_state hidden
}

center_hide_delayed() {
    if ! center_autohide_enabled; then
        eww update center_bar_auto=false >/dev/null 2>&1 || true
        return
    fi
    local delay token
    delay="${1:-0.32}"
    cancel_center_hide
    set_center_state visible
    token="$$-$RANDOM-$RANDOM"
    printf '%s' "$token" > "$hide_token_file"
    (
        local current_token
        sleep "$delay"
        [[ -f "$hide_token_file" ]] || exit 0
        current_token=$(<"$hide_token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        tooltip_hide
        set_center_state hiding
        eww update center_bar_hiding=false >/dev/null 2>&1 || true
        open_window_for_serial bar-center-hide "$(center_target_serial)" "$(center_target_name)" "center"
        sleep "$hide_reveal_kick_delay"
        [[ -f "$hide_token_file" ]] || exit 0
        current_token=$(<"$hide_token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        close_window bar-center-home
        eww update center_bar_hiding=true >/dev/null 2>&1 || true
        sleep "$hide_anim_delay"
        [[ -f "$hide_token_file" ]] || exit 0
        current_token=$(<"$hide_token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        close_window bar-center-hide
        open_window_for_serial bar-center-trigger "$(center_target_serial)" "$(center_target_name)" "center"
        set_center_state hidden
        rm -f "$hide_pid_file" "$hide_token_file"
    ) &
    printf '%s' "$!" > "$hide_pid_file"
}

case "${1:-start}" in
start)
    eww daemon
    prepare_workspace_layout
    open_bars
    open_center_windows
    ;;
reload)
    eww reload
    prepare_workspace_layout
    open_bars
    open_center_windows
    ;;
stop)
    tooltip_hide
    eww close-all
    rm -f "$hide_pid_file" "$hide_token_file" "$center_state_file"
    ;;
tooltip-show)
    tooltip_show "${2:?usage: eww-bar tooltip-show <spotify|network|bluetooth|brightness|audio|cpu|memory|battery|power|clock>}"
    ;;
tooltip-hide)
    tooltip_hide
    ;;
toggle)
    toggle_panel "${2:?usage: eww-bar toggle <network|bluetooth|audio|brightness|power>}"
    ;;
close-panels)
    close_panels
    ;;
close-panel)
    close_panel "${2:?usage: eww-bar close-panel <network|bluetooth|audio|brightness|power>}"
    ;;
touch-panel)
    touch_panel "${2:?usage: eww-bar touch-panel <network|bluetooth|audio|brightness|power>}"
    ;;
schedule-panel-close)
    schedule_panel_close "${2:?usage: eww-bar schedule-panel-close <name> [delay]}" "${3:-$panel_idle_delay}"
    ;;
center-show)
    center_show
    ;;
center-hide)
    center_hide
    ;;
center-hide-delayed)
    center_hide_delayed "${2:-0.32}"
    ;;
*)
    echo "Usage: $0 {start|reload|stop|toggle|close-panels|close-panel|touch-panel|schedule-panel-close|center-show|center-hide|center-hide-delayed [delay]|tooltip-show <target>|tooltip-hide}"
    exit 2
    ;;
esac
