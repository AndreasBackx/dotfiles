#!/usr/bin/env zsh

set -euo pipefail

panels=(panel-network panel-bluetooth panel-audio panel-brightness panel-power)
panel_names=(network bluetooth audio brightness power)
bars=(bar-left bar-right)
left_serial='{{ index .monitors .monitors.selected "left" "serial_number" }}'
center_serial='{{ index .monitors .monitors.selected "center" "serial_number" }}'
right_serial='{{ index .monitors .monitors.selected "right" "serial_number" }}'
home_center_name='{{ index .monitors.home.center "name" }}'
home_center_serial='{{ index .monitors.home.center "serial_number" }}'

hide_pid_file="${XDG_RUNTIME_DIR:-/tmp}/eww-center-hide.pid"
hide_token_file="${XDG_RUNTIME_DIR:-/tmp}/eww-center-hide.token"
hide_anim_delay=0.24
hide_reveal_kick_delay=0.01
panel_idle_delay=5

panel_name() {
    local name="${1:?panel name required}"
    name=${name#panel-}

    case "$name" in
    network | bluetooth | audio | brightness | power)
        print -r -- "$name"
        ;;
    *)
        echo "Unknown panel: $name" >&2
        return 1
        ;;
    esac
}

panel_target() {
    print -r -- "panel-$(panel_name "$1")"
}

panel_pid_file() {
    print -r -- "${XDG_RUNTIME_DIR:-/tmp}/eww-panel-$(panel_name "$1").pid"
}

panel_token_file() {
    print -r -- "${XDG_RUNTIME_DIR:-/tmp}/eww-panel-$(panel_name "$1").token"
}

close_panels() {
    local name
    for name in "${panel_names[@]}"; do
        close_panel "$name"
    done
}

cancel_panel_close() {
    local name pid_file token_file panel_pid
    name=$(panel_name "$1") || return 1
    pid_file=$(panel_pid_file "$name")
    token_file=$(panel_token_file "$name")

    if [[ -f "$pid_file" ]]; then
        panel_pid=$(<"$pid_file")
        if [[ -n "$panel_pid" ]]; then
            kill "$panel_pid" >/dev/null 2>&1 || true
        fi
        rm -f "$pid_file"
    fi

    rm -f "$token_file"
}

touch_panel() {
    cancel_panel_close "$1"
}

window_is_open() {
    local target="$1"
    eww active-windows 2>/dev/null | grep -q "^${target}:\|^${target}$"
}

monitor_connector_for_serial() {
    local serial="${1:?monitor serial required}"

    hyprctl -j monitors all 2>/dev/null | jq -r --arg serial "$serial" '.[] | select(.serial == $serial) | .name' | head -n1
}

monitor_connector_required() {
    local serial="${1:?monitor serial required}"
    local label="${2:-monitor}"
    local connector

    connector=$(monitor_connector_for_serial "$serial")

    if [[ -z "$connector" || "$connector" == "null" ]]; then
        echo "Could not resolve ${label} serial ${serial} to a connector" >&2
        return 1
    fi

    print -r -- "$connector"
}

open_window() {
    local target="$1"
    if ! window_is_open "$target"; then
        eww open "$target" >/dev/null 2>&1 || true
    fi
}

open_window_on_screen() {
    local target="${1:?window required}"
    local screen="${2:?screen required}"
    if ! window_is_open "$target"; then
        eww open "$target" --screen "$screen" >/dev/null 2>&1 || true
    fi
}

open_window_for_serial() {
    local target="${1:?window required}"
    local serial="${2:?serial required}"
    local label="${3:-$target}"
    local connector

    connector=$(monitor_connector_required "$serial" "$label") || return 1
    open_window_on_screen "$target" "$connector"
}

close_window() {
    local target="$1"
    if window_is_open "$target"; then
        eww close "$target" >/dev/null 2>&1 || true
    fi
}

close_panel() {
    local name target
    name=$(panel_name "$1") || return 1
    target=$(panel_target "$name")
    cancel_panel_close "$name"
    close_window "$target"
}

schedule_panel_close() {
    local name delay token pid_file token_file target
    name=$(panel_name "$1") || return 1
    delay="${2:-$panel_idle_delay}"
    target=$(panel_target "$name")
    pid_file=$(panel_pid_file "$name")
    token_file=$(panel_token_file "$name")

    cancel_panel_close "$name"
    token="$$-$RANDOM-$RANDOM"
    printf '%s' "$token" > "$token_file"

    (
        local current_token
        sleep "$delay"
        [[ -f "$token_file" ]] || exit 0
        current_token=$(<"$token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        close_window "$target"
        rm -f "$pid_file" "$token_file"
    ) &

    printf '%s' "$!" > "$pid_file"
}

toggle_panel() {
    local name target
    name=$(panel_name "$1") || return 1
    target=$(panel_target "$name")

    if window_is_open "$target"; then
        close_panel "$name"
        return
    fi

    close_panels
    open_window_for_serial "$target" "$center_serial" "center"
    schedule_panel_close "$name"
}

center_autohide_enabled() {
    local monitors
    monitors="$(hyprctl monitors all 2>/dev/null || true)"
    [[ -n "$monitors" ]] || return 1
    [[ "$monitors" == *"$home_center_name"* ]] || return 1
    [[ -z "$home_center_serial" || "$monitors" == *"$home_center_serial"* ]]
}

open_bars() {
    open_window_for_serial bar-left "$left_serial" "left"
    open_window_for_serial bar-right "$right_serial" "right"
}

open_center_windows() {
    if center_autohide_enabled; then
        close_window bar-center
        eww update center_bar_auto=true >/dev/null 2>&1 || true
        eww update center_bar_hiding=false >/dev/null 2>&1 || true
        close_window bar-center-home
        close_window bar-center-hide
    open_window_for_serial bar-center-trigger "$center_serial" "center"
        return
    fi

    eww update center_bar_hiding=false >/dev/null 2>&1 || true
    close_window bar-center-home
    close_window bar-center-hide
    close_window bar-center-trigger
    eww update center_bar_auto=false >/dev/null 2>&1 || true
    open_window_for_serial bar-center "$center_serial" "center"
}

cancel_center_hide() {
    local hide_pid
    if [[ -f "$hide_pid_file" ]]; then
        hide_pid=$(<"$hide_pid_file")
        if [[ -n "$hide_pid" ]]; then
            kill "$hide_pid" >/dev/null 2>&1 || true
        fi
        rm -f "$hide_pid_file"
    fi
    rm -f "$hide_token_file"
}

center_show() {
    if ! center_autohide_enabled; then
        eww update center_bar_auto=false >/dev/null 2>&1 || true
        return
    fi
    cancel_center_hide
    eww update center_bar_hiding=false >/dev/null 2>&1 || true
    close_window bar-center-hide
    close_window bar-center-trigger
    open_window_for_serial bar-center-home "$center_serial" "center"
}

center_hide() {
    if ! center_autohide_enabled; then
        eww update center_bar_auto=false >/dev/null 2>&1 || true
        return
    fi
    cancel_center_hide
    eww update center_bar_hiding=false >/dev/null 2>&1 || true
    open_window_for_serial bar-center-hide "$center_serial" "center"
    sleep "$hide_reveal_kick_delay"
    close_window bar-center-home
    eww update center_bar_hiding=true >/dev/null 2>&1 || true
    sleep "$hide_anim_delay"
    close_window bar-center-hide
    open_window_for_serial bar-center-trigger "$center_serial" "center"
}

center_hide_delayed() {
    if ! center_autohide_enabled; then
        eww update center_bar_auto=false >/dev/null 2>&1 || true
        return
    fi
    local delay token
    delay="${1:-0.32}"
    cancel_center_hide
    token="$$-$RANDOM-$RANDOM"
    printf '%s' "$token" > "$hide_token_file"
    (
        local current_token
        sleep "$delay"
        [[ -f "$hide_token_file" ]] || exit 0
        current_token=$(<"$hide_token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        eww update center_bar_hiding=false >/dev/null 2>&1 || true
        open_window_for_serial bar-center-hide "$center_serial" "center"
        sleep "$hide_reveal_kick_delay"
        [[ -f "$hide_token_file" ]] || exit 0
        current_token=$(<"$hide_token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        close_window bar-center-home
        eww update center_bar_hiding=true >/dev/null 2>&1 || true
        sleep "$hide_anim_delay"
        [[ -f "$hide_token_file" ]] || exit 0
        current_token=$(<"$hide_token_file")
        [[ "$current_token" == "$token" ]] || exit 0
        close_window bar-center-hide
        open_window_for_serial bar-center-trigger "$center_serial" "center"
        rm -f "$hide_pid_file" "$hide_token_file"
    ) &
    printf '%s' "$!" > "$hide_pid_file"
}

case "${1:-start}" in
start)
    eww daemon
    open_bars
    open_center_windows
    ;;
reload)
    eww reload
    open_bars
    open_center_windows
    ;;
stop)
    eww close-all
    ;;
toggle)
    toggle_panel "${2:?usage: eww-bar toggle <network|bluetooth|audio|brightness|power>}"
    ;;
close-panels)
    close_panels
    ;;
close-panel)
    close_panel "${2:?usage: eww-bar close-panel <network|bluetooth|audio|brightness|power>}"
    ;;
touch-panel)
    touch_panel "${2:?usage: eww-bar touch-panel <network|bluetooth|audio|brightness|power>}"
    ;;
schedule-panel-close)
    schedule_panel_close "${2:?usage: eww-bar schedule-panel-close <name> [delay]}" "${3:-$panel_idle_delay}"
    ;;
center-show)
    center_show
    ;;
center-hide)
    center_hide
    ;;
center-hide-delayed)
    center_hide_delayed "${2:-0.32}"
    ;;
*)
    echo "Usage: $0 {start|reload|stop|toggle|close-panels|close-panel|touch-panel|schedule-panel-close|center-show|center-hide|center-hide-delayed [delay]}"
    exit 2
    ;;
esac
