#!/usr/bin/env zsh

set -euo pipefail

powered() {
    local value
    value=$(bluetoothctl show 2>/dev/null | awk '/Powered:/ {print $2; exit}' || true)
    if [[ -z "$value" ]]; then
        echo "no"
    else
        echo "$value"
    fi
}

connected_devices() {
    bluetoothctl devices Connected 2>/dev/null || true
}

state() {
    local is_powered first_connected
    is_powered=$(powered)

    if [[ "$is_powered" != "yes" ]]; then
        echo "off"
        return
    fi

    first_connected=$(connected_devices | awk 'NR == 1 {print}')
    if [[ -n "$first_connected" ]]; then
        echo "connected"
    else
        echo "on"
    fi
}

icon() {
    local is_powered first_connected
    is_powered=$(powered)

    if [[ "$is_powered" != "yes" ]]; then
        echo "󰂲"
        return
    fi

    first_connected=$(connected_devices | awk 'NR == 1 {print}')
    if [[ -n "$first_connected" ]]; then
        echo "󰂱"
    else
        echo "󰂯"
    fi
}

tooltip() {
    local is_powered devices count first_name

    is_powered=$(powered)
    if [[ "$is_powered" != "yes" ]]; then
        echo "Bluetooth: off"
        return
    fi

    devices=$(connected_devices)
    count=$(wc -l <<<"$devices" | awk '{print $1}')

    if [[ -z "$devices" || "$count" -eq 0 ]]; then
        echo "On, no device"
        return
    fi

    first_name=$(awk 'NR == 1 {sub(/^Device [^ ]+ /, ""); print; exit}' <<<"$devices")
    if (( count == 1 )); then
        echo "Connected: ${first_name}"
    else
        echo "Connected: ${first_name} (+$((count - 1)) more)"
    fi
}

toggle_power() {
    if [[ "$(powered)" == "yes" ]]; then
        bluetoothctl power off
    else
        bluetoothctl power on
    fi
}

connect_device() {
    local mac="$1"
    bluetoothctl connect "$mac" || true
}

disconnect_device() {
    local mac="$1"
    bluetoothctl disconnect "$mac" || true
}

case "${1:-icon}" in
icon)
    icon
    ;;
tooltip)
    tooltip
    ;;
state)
    state
    ;;
toggle-power)
    toggle_power
    ;;
connect)
    connect_device "${2:?mac required}"
    ;;
disconnect)
    disconnect_device "${2:?mac required}"
    ;;
*)
    echo "Usage: $0 {icon|tooltip|state|toggle-power|connect|disconnect}"
    exit 2
    ;;
esac
