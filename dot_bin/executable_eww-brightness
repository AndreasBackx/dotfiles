#!/usr/bin/env zsh

set -euo pipefail

resolve_backend() {
    case "${1:-minos}" in
    minos | brightnessctl)
        print -r -- "${1:-minos}"
        ;;
    *)
        print -r -- "minos"
        ;;
    esac
}

get_brightness_minos() {
    local raw value
    local -a values

    raw=$(minos get --minimal --brightness 2>/dev/null || true)
    values=(${(@f)$(printf '%s\n' "$raw" | awk '/Brightness:/ {gsub(/%/, "", $2); print int($2)}')})

    value=$(select_brightness_value "${values[@]}")

    if [[ -z "$value" ]]; then
        echo 0
    else
        echo "$value"
    fi
}

get_brightness_brightnessctl() {
    local value max

    value=$(brightnessctl g 2>/dev/null || true)
    max=$(brightnessctl m 2>/dev/null || true)

    if [[ -z "$value" || -z "$max" || "$max" == "0" ]]; then
        echo 0
        return
    fi

    echo $(( (value * 100) / max ))
}

get_brightness() {
    case "$(resolve_backend "$1")" in
    brightnessctl)
        get_brightness_brightnessctl
        ;;
    *)
        get_brightness_minos
        ;;
    esac
}

select_brightness_value() {
    local -a values
    values=("$@")

    if (( ${#values[@]} >= 2 )); then
        echo "${values[2]}"
    elif (( ${#values[@]} >= 1 )); then
        echo "${values[1]}"
    else
        echo 0
    fi
}

clamp_brightness() {
    local value="$1"

    if (( value < 0 )); then
        echo 0
    elif (( value > 100 )); then
        echo 100
    else
        echo "$value"
    fi
}

panel_markup() {
    local value="$1"
    print '(box :orientation "v" :spacing 8 :class "panel-state-normal"'
    print '  (box :class "panel-header" :orientation "h" :spacing 8 :space-evenly false'
    print '    (label :class "panel-title" :hexpand true :xalign 0 :text "Brightness")'
    print '    (button :class "panel-button panel-close" :onclick "~/.bin/eww-bar close-panel brightness" "x"))'
    print "  (label :class \"panel-status\" :text \"󰃠 ${value}%\")"
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness down" "-10%")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness up" "+10%"))'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness set 0" "0")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness set 25" "25")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness set 50" "50")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness set 75" "75")'
    print '    (button :class "panel-button" :onclick "~/.bin/eww-bar schedule-panel-close brightness; eww-brightness set 100" "100"))'
    print ')'
}

status() {
    local backend="${1:-minos}"
    echo "$(icon) $(text "$backend")"
}

icon() {
    echo "󰃠"
}

text() {
    local backend="${1:-minos}"
    local value
    value=$(get_brightness "$backend")
    echo "${value}%"
}

tooltip() {
    local backend="${1:-minos}"
    local value
    value=$(get_brightness "$backend")
    echo "Brightness: ${value}%"
}

panel_state() {
    local backend="${1:-minos}"
    local value
    value=$(get_brightness "$backend")
    if (( value <= 5 )); then
        echo "low"
    else
        echo "normal"
    fi
}

render() {
    local backend="${1:-minos}"
    local value
    value=$(get_brightness "$backend")
    panel_markup "$value"
}

refresh_with_value() {
    local value="$1"
    local panel_state panel_content

    if (( value <= 5 )); then
        panel_state="low"
    else
        panel_state="normal"
    fi
    panel_content=$(panel_markup "$value")

    eww update \
        brightness_icon="$(icon)" \
        brightness_text="${value}%" \
        brightness_tooltip="Brightness: ${value}%" \
        brightness_panel_state="$panel_state" \
        brightness_panel="$panel_content"
}

refresh() {
    local backend="${1:-minos}"
    refresh_with_value "$(get_brightness "$backend")"
}

refresh_after_relative_set() {
    local backend="$1"
    local step="$2"
    local current value
    shift 2

    current=$(get_brightness "$backend")
    "$@" || return
    value=$(clamp_brightness $(( current + step )))
    refresh_with_value "$value"
}

refresh_after_absolute_set() {
    local backend="$1"
    local target="$2"
    shift 2

    "$@" || return
    refresh_with_value "$(clamp_brightness "$target")"
}

backend=$(resolve_backend "$1")

if [[ "$backend" == "${1:-}" ]]; then
    shift
fi

case "${1:-status}" in
status)
    status "$backend"
    ;;
icon)
    icon
    ;;
text)
    text "$backend"
    ;;
tooltip)
    tooltip "$backend"
    ;;
panel-state)
    panel_state "$backend"
    ;;
render)
    render "$backend"
    ;;
refresh)
    refresh "$backend"
    ;;
up)
    if [[ "$backend" == "brightnessctl" ]]; then
        refresh_after_relative_set "$backend" 10 brightnessctl set 10%+
    else
        refresh_after_relative_set "$backend" 10 minos set --minimal --brightness +10%
    fi
    ;;
down)
    if [[ "$backend" == "brightnessctl" ]]; then
        refresh_after_relative_set "$backend" -10 brightnessctl set 10%-
    else
        refresh_after_relative_set "$backend" -10 minos set --minimal --brightness -10%
    fi
    ;;
set)
    if [[ "$backend" == "brightnessctl" ]]; then
        refresh_after_absolute_set "$backend" "${2:?brightness required}" brightnessctl set "${2:?brightness required}%"
    else
        refresh_after_absolute_set "$backend" "${2:?brightness required}" minos set --minimal --brightness "${2:?brightness required}%"
    fi
    ;;
*)
    echo "Usage: $0 [minos|brightnessctl] {status|icon|text|tooltip|panel-state|render|refresh|up|down|set}"
    exit 2
    ;;
esac
