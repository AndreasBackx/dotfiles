#!/usr/bin/env zsh

set -euo pipefail

get_brightness() {
    local value
    value=$(minos get --output-format simple --brightness 2>/dev/null | awk 'NR == 1 {gsub(/%/, "", $1); print int($1)}')
    if [[ -z "$value" ]]; then
        echo 0
    else
        echo "$value"
    fi
}

status() {
    echo "$(icon) $(text)"
}

icon() {
    echo "󰃠"
}

text() {
    local value
    value=$(get_brightness)
    echo "${value}%"
}

tooltip() {
    local value
    value=$(get_brightness)
    echo "Brightness: ${value}%"
}

panel_state() {
    local value
    value=$(get_brightness)
    if (( value <= 5 )); then
        echo "low"
    else
        echo "normal"
    fi
}

render() {
    local value
    value=$(get_brightness)
    print '(box :orientation "v" :spacing 8 :class "panel-state-normal"'
    print '  (label :class "panel-title" :text "Brightness")'
    print "  (label :class \"panel-status\" :text \"󰃠 ${value}%\")"
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "eww-brightness down" "-10%")'
    print '    (button :class "panel-button" :onclick "eww-brightness up" "+10%"))'
    print '  (box :class "panel-row" :orientation "h" :spacing 8'
    print '    (button :class "panel-button" :onclick "eww-brightness set 0" "0")'
    print '    (button :class "panel-button" :onclick "eww-brightness set 25" "25")'
    print '    (button :class "panel-button" :onclick "eww-brightness set 50" "50")'
    print '    (button :class "panel-button" :onclick "eww-brightness set 75" "75")'
    print '    (button :class "panel-button" :onclick "eww-brightness set 100" "100"))'
    print ')'
}

case "${1:-status}" in
status)
    status
    ;;
icon)
    icon
    ;;
text)
    text
    ;;
tooltip)
    tooltip
    ;;
panel-state)
    panel_state
    ;;
render)
    render
    ;;
up)
    minos set --brightness +10%
    ;;
down)
    minos set --brightness -10%
    ;;
set)
    minos set --brightness "${2:?brightness required}%"
    ;;
*)
    echo "Usage: $0 {status|icon|text|tooltip|panel-state|render|up|down|set}"
    exit 2
    ;;
esac
