#!/usr/bin/env zsh

set -euo pipefail

class_string() {
    jq -r '
        .class // empty
        | if type == "array" then join(" ") else . end
        | ascii_downcase
    ' 2>/dev/null || true
}

monitor() {
    spotifatius monitor 2>/dev/null | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if ! jq -e . >/dev/null 2>&1 <<<"$line"; then
            continue
        fi

        local text class_json
        text=$(jq -r '.text // ""' <<<"$line")
        text=${text//$'\n'/ }
        class_json=$(class_string <<<"$line")

        if [[ "$class_json" == *playing* ]] && [[ -n "$text" ]]; then
            echo "$text"
        else
            echo ""
        fi
    done
}

monitor_tooltip() {
    spotifatius monitor 2>/dev/null | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if ! jq -e . >/dev/null 2>&1 <<<"$line"; then
            continue
        fi

        local text class_json
        text=$(jq -r '.tooltip // .text // ""' <<<"$line")
        text=${text//$'\n'/ }
        class_json=$(class_string <<<"$line")

        if [[ "$class_json" == *playing* ]] && [[ -n "$text" ]]; then
            echo "$text"
        else
            echo ""
        fi
    done
}

monitor_state() {
    spotifatius monitor 2>/dev/null | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if ! jq -e . >/dev/null 2>&1 <<<"$line"; then
            continue
        fi

        jq -r '
            def normalize_class:
                if . == null then []
                elif type == "array" then .
                else [.] end;

            (.class | normalize_class) as $class
            | if ($class | index("playing")) != null then "playing"
              elif ($class | index("paused")) != null then "paused"
              elif ($class | index("stopped")) != null then "stopped"
              else (.state // "paused")
              end
        ' <<<"$line"
    done
}

tooltip() {
    local playback_status title artist album

    playback_status=$(playerctl -p spotify status 2>/dev/null || true)
    [[ "$playback_status" == "Playing" ]] || {
        echo ""
        return 0
    }

    title=$(playerctl -p spotify metadata xesam:title 2>/dev/null || true)
    artist=$(playerctl -p spotify metadata xesam:artist 2>/dev/null | paste -sd ', ' - || true)
    album=$(playerctl -p spotify metadata xesam:album 2>/dev/null || true)

    [[ -n "$title" ]] || {
        echo ""
        return 0
    }

    print -r -- "$title"
    [[ -n "$artist" ]] && print -r -- "$artist"
    [[ -n "$album" ]] && print -r -- "$album"
}

case "${1:-monitor}" in
monitor)
    monitor
    ;;
monitor-tooltip)
    monitor_tooltip
    ;;
monitor-state)
    monitor_state
    ;;
tooltip)
    tooltip
    ;;
toggle-liked)
    spotifatius toggle-liked
    ;;
*)
    echo "Usage: $0 {monitor|monitor-tooltip|monitor-state|tooltip|toggle-liked}"
    exit 2
    ;;
esac
