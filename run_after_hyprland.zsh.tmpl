#!/usr/bin/env zsh

{{ if .headless }}
# We're headless.
exit 0
{{ end }}

set -o errexit -o nounset -o pipefail

hyprland_log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/hyprland"
mkdir -p "$hyprland_log_dir"

if command -v systemctl >/dev/null 2>&1; then
    systemctl --user daemon-reload
    systemctl --user enable --now logrotate-hyprland.timer >/dev/null
fi
